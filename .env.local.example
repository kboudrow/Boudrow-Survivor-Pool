# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_POOL_ACTIVATION_PRICE_ID=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google AdSense
# Set this to true only when ad slots should render.
NEXT_PUBLIC_ENABLE_ADSENSE=false

# Client format usually looks like: ca-pub-1234567890123456
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=

# Slot IDs are numeric strings created in Google AdSense.
# Blog pages intentionally have more ad inventory than app workflow pages.
NEXT_PUBLIC_AD_SLOT_BLOG_TOP=
NEXT_PUBLIC_AD_SLOT_BLOG_BOTTOM=
NEXT_PUBLIC_AD_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_AD_SLOT_ARTICLE_INLINE=
NEXT_PUBLIC_AD_SLOT_ARTICLE_BOTTOM=

# Used sparingly on home, join, and my-pools pages.
NEXT_PUBLIC_AD_SLOT_SITE_INLINE=
